{
  "name": "@vasichmen/js-base-api",
  "version": "0.0.1",
  "keywords": [
    "js",
    "api"
  ],
  "author": "vasichmen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasichmen/js-base-api"
  },
  "description": "JS library for interact with backend API",
  "main": "dist/js-base-api.umd.js",
  "module": "dist/js-base-api.esm.js",
  "unpkg": "dist/js-base-api.min.js",
  "browser": {
    "./sfc": "src/js-base-api.vue"
  },
  "files": [
    "dist/*",
    "src/*"
  ],
  "scripts": {
    "build": "npm run build:umd & npm run build:es & npm run build:unpkg",
    "build:umd": "rollup --config build/rollup.config.js --format umd --file dist/js-base-api.umd.js",
    "build:es": "rollup --config build/rollup.config.js --format es --file dist/js-base-api.esm.js",
    "build:unpkg": "rollup --config build/rollup.config.js --format iife --file dist/js-base-api.min.js"
  },
  "devDependencies": {
    "@rollup/plugin-buble": "^0.21.3",
    "@rollup/plugin-commonjs": "^11.1.0",
    "rollup": "^1.17.0"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "object-to-formdata": "^4.5.1"
  }
}
